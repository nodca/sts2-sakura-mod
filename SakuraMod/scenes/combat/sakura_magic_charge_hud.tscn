[sub_resource type="Shader" id="Shader_magic_liquid"]
code = "shader_type canvas_item;\n\nuniform float fill_ratio : hint_range(0.0, 1.0) = 0.0;\nuniform vec4 deep_magic : source_color = vec4(0.13, 0.46, 0.56, 0.58);\nuniform vec4 moonlight : source_color = vec4(0.64, 0.87, 0.88, 0.82);\n\nvoid fragment() {\n    vec4 mask = texture(TEXTURE, UV);\n    float ratio = clamp(fill_ratio, 0.0, 1.0);\n    float surface_y = mix(1.04, -0.04, ratio);\n    float wave = (sin(UV.x * 17.0 + TIME * 0.75) + sin(UV.x * 37.0 - TIME * 0.42) * 0.35) * 0.007;\n    float liquid = smoothstep(surface_y + wave - 0.012, surface_y + wave + 0.012, UV.y);\n    float drift_a = 0.5 + 0.5 * sin(UV.y * 18.0 + UV.x * 7.0 - TIME * 0.65);\n    float drift_b = 0.5 + 0.5 * sin(UV.y * 31.0 - UV.x * 11.0 + TIME * 0.38);\n    float shimmer = drift_a * 0.65 + drift_b * 0.35;\n    vec3 color = mix(deep_magic.rgb, moonlight.rgb, 0.16 + shimmer * 0.22);\n    float surface = 1.0 - smoothstep(0.0, 0.022, abs(UV.y - surface_y - wave));\n    float has_surface = step(0.001, ratio) * (1.0 - step(0.999, ratio));\n    color = mix(color, moonlight.rgb, surface * has_surface * 0.48);\n    float alpha = mask.a * liquid * (deep_magic.a + shimmer * 0.09);\n    alpha += mask.a * surface * has_surface * 0.22;\n    COLOR = vec4(color, clamp(alpha, 0.0, 0.82));\n}\n"

